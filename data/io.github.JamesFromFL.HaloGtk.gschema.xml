<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="io.github.JamesFromFL.HaloGtk" path="/io/github/JamesFromFL/HaloGtk/">
    <key name="start-minimised" type="b">
      <default>false</default>
      <summary>Start minimised to tray</summary>
    </key>
    <key name="show-notifications" type="b">
      <default>true</default>
      <summary>Show desktop notifications for Ring events</summary>
    </key>
    <key name="poll-interval" type="i">
      <default>30</default>
      <range min="10" max="300"/>
      <summary>Device poll interval (seconds)</summary>
    </key>
    <key name="window-width" type="i">
      <default>480</default>
      <summary>Last window width</summary>
    </key>
    <key name="window-height" type="i">
      <default>640</default>
      <summary>Last window height</summary>
    </key>
  </schema>
</schemalist>
